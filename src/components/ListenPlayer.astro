---
// Listen player — a quiet, editorial audio control for the post narration.
// Renders nothing when no src is provided.
interface Props {
  src?: string;
}
const { src } = Astro.props;
---

{src && (
  <div class="listen" data-listen role="group" aria-label="Listen to this post">
    <audio preload="metadata" src={src}></audio>

    <button class="listen__toggle" type="button" aria-label="Play narration" data-toggle>
      <svg class="listen__icon listen__icon--play" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z" /></svg>
      <svg class="listen__icon listen__icon--pause" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 5h3.2v14H7zM13.8 5H17v14h-3.2z" /></svg>
    </button>

    <div class="listen__main">
      <div class="listen__row">
        <span class="listen__label">Listen to this post</span>
        <span class="listen__time"><span data-current>0:00</span> / <span data-duration>--:--</span></span>
      </div>
      <button class="listen__track" type="button" aria-label="Seek" data-track>
        <span class="listen__fill" data-fill></span>
      </button>
    </div>
  </div>
)}

<style>
  .listen {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 0 0 2.75rem;
  }

  .listen__toggle {
    flex: none;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid #c9b99a;
    background: transparent;
    color: #c9b99a;
    display: grid;
    place-items: center;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.25s ease, color 0.25s ease, transform 0.15s ease;
  }

  .listen__toggle:hover {
    background: #c9b99a;
    color: #0d0d0d;
  }

  .listen__toggle:active {
    transform: scale(0.95);
  }

  .listen__icon {
    width: 18px;
    height: 18px;
    fill: currentColor;
    /* nudge play triangle to optical center */
    transform: translateX(1px);
  }

  .listen__icon--pause {
    display: none;
    transform: none;
  }

  .listen.is-playing .listen__icon--play {
    display: none;
  }

  .listen.is-playing .listen__icon--pause {
    display: block;
  }

  .listen__main {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .listen__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .listen__label {
    font-family: "Source Serif 4", serif;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #c9b99a;
  }

  .listen__time {
    font-family: "Source Serif 4", serif;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: #c9b99a;
    opacity: 0.7;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .listen__track {
    position: relative;
    width: 100%;
    height: 2px;
    background: rgba(201, 185, 154, 0.22);
    border: none;
    padding: 0;
    margin: 0;
    border-radius: 2px;
    cursor: pointer;
    appearance: none;
  }

  /* generous invisible hit area for easy seeking */
  .listen__track::before {
    content: "";
    position: absolute;
    inset: -11px 0;
  }

  .listen__fill {
    display: block;
    height: 100%;
    width: 0%;
    background: #c9b99a;
    border-radius: 2px;
    transition: width 0.1s linear;
  }

  .listen__toggle:focus-visible,
  .listen__track:focus-visible {
    outline: 2px solid #f0e6d0;
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .listen__fill,
    .listen__toggle {
      transition: none;
    }
  }

  @media (max-width: 768px) {
    .listen {
      gap: 0.85rem;
      margin-bottom: 2.25rem;
    }
    .listen__toggle {
      width: 42px;
      height: 42px;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-listen]").forEach((root) => {
    const audio = root.querySelector("audio");
    const toggle = root.querySelector<HTMLButtonElement>("[data-toggle]");
    const track = root.querySelector<HTMLElement>("[data-track]");
    const fill = root.querySelector<HTMLElement>("[data-fill]");
    const cur = root.querySelector<HTMLElement>("[data-current]");
    const dur = root.querySelector<HTMLElement>("[data-duration]");
    if (!audio || !toggle || !track) return;

    const fmt = (s: number) => {
      if (!isFinite(s)) return "--:--";
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m}:${String(sec).padStart(2, "0")}`;
    };

    toggle.addEventListener("click", () => {
      audio.paused ? audio.play() : audio.pause();
    });

    audio.addEventListener("play", () => {
      root.classList.add("is-playing");
      toggle.setAttribute("aria-label", "Pause narration");
    });
    audio.addEventListener("pause", () => {
      root.classList.remove("is-playing");
      toggle.setAttribute("aria-label", "Play narration");
    });

    audio.addEventListener("loadedmetadata", () => {
      if (dur) dur.textContent = fmt(audio.duration);
    });

    audio.addEventListener("timeupdate", () => {
      const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
      if (fill) fill.style.width = `${pct}%`;
      if (cur) cur.textContent = fmt(audio.currentTime);
    });

    audio.addEventListener("ended", () => {
      root.classList.remove("is-playing");
      if (fill) fill.style.width = "0%";
      if (cur) cur.textContent = fmt(0);
      audio.currentTime = 0;
    });

    const seek = (clientX: number) => {
      const rect = track.getBoundingClientRect();
      const ratio = Math.min(Math.max((clientX - rect.left) / rect.width, 0), 1);
      if (isFinite(audio.duration)) audio.currentTime = ratio * audio.duration;
    };
    track.addEventListener("click", (e) => seek((e as MouseEvent).clientX));
  });
</script>
