---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Helper to convert number to Roman numerals
function toRoman(num: number): string {
  const romanMap = [
    { value: 1000, numeral: 'M' },
    { value: 900, numeral: 'CM' },
    { value: 500, numeral: 'D' },
    { value: 400, numeral: 'CD' },
    { value: 100, numeral: 'C' },
    { value: 90, numeral: 'XC' },
    { value: 50, numeral: 'L' },
    { value: 40, numeral: 'XL' },
    { value: 10, numeral: 'X' },
    { value: 9, numeral: 'IX' },
    { value: 5, numeral: 'V' },
    { value: 4, numeral: 'IV' },
    { value: 1, numeral: 'I' },
  ];
  
  let roman = '';
  let n = num;
  for (const { value, numeral } of romanMap) {
    while (n >= value) {
      roman += numeral;
      n -= value;
    }
  }
  return roman;
}
---

<Base title="Watson Works">
  <div class="post-list">
    {posts.map((post, index) => {
      const formatted = new Date(post.data.date + 'T12:00:00').toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      });
      // Publication order: oldest = I, newest = highest number
      const publicationNumber = posts.length - index;
      return (
        <div class="post-item">
          <div class="post-number">{toRoman(publicationNumber)}</div>
          <div class="post-info">
            <h2><a href={`/posts/${post.data.slug}`}>{post.data.title}</a></h2>
            <span class="post-date">{formatted}</span>
            <p class="post-description">{post.data.description}</p>
          </div>
        </div>
      );
    })}
  </div>
</Base>

<style>
  .post-list {
    display: block;
  }

  .post-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 2rem;
    padding: 2rem 0;
    border-bottom: 1px solid #c9b99a;
    transition: opacity 0.3s ease;
  }

  .post-item:last-child {
    border-bottom: none;
  }

  .post-item:hover {
    opacity: 0.9;
  }

  .post-number {
    font-family: "Playfair Display", serif;
    font-size: 3.5rem;
    font-weight: 400;
    color: #c9b99a;
    opacity: 0.4;
    text-align: right;
    line-height: 1;
  }

  .post-info h2 {
    font-family: "Playfair Display", serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .post-info h2 a {
    position: relative;
    display: inline-block;
    color: #e8e4d9;
    text-decoration: none;
  }

  .post-info h2 a::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: #f0e6d0;
    transition: width 0.5s ease;
  }

  .post-item:hover h2 a {
    color: #f0e6d0;
  }

  .post-item:hover h2 a::after {
    width: 100%;
  }

  .post-date {
    font-family: "Source Serif 4", serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #c9b99a;
    margin-bottom: 0.75rem;
    display: block;
  }

  .post-description {
    font-size: 0.95rem;
    color: #c9b99a;
    font-style: italic;
    margin: 0;
  }

  @media (max-width: 768px) {
    .post-item {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .post-number {
      text-align: left;
      margin-bottom: 0.5rem;
    }
  }
</style>
