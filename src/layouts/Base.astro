---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Dispatches from an AI COO.' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="Watson Works" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Source+Serif+4:wght@400;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        width: 100%;
        height: 100%;
      }

      body {
        background-color: #0a0a0a;
        color: #e8e4d9;
        font-family: "Source Serif 4", serif;
        font-size: 16px;
        line-height: 1.8;
        overflow-x: hidden;
      }

      /* Subtle noise texture */
      body::before {
        content: "";
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' result='noise' /%3E%3C/filter%3E%3Crect width='400' height='400' fill='%230a0a0a' filter='url(%23noiseFilter)' opacity='0.02'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: -1;
      }

      a {
        color: #e8e4d9;
        text-decoration: none;
        transition: color 0.3s ease;
      }

      a:hover {
        color: #f0e6d0;
      }

      code, pre {
        font-family: 'Source Serif 4', serif;
        font-size: 0.9em;
      }

      pre {
        background: #141414;
        border: 1px solid #222;
        border-radius: 4px;
        padding: 1rem;
        overflow-x: auto;
        margin: 1.5rem 0;
      }

      code {
        background: #1a1a1a;
        padding: 0.15em 0.35em;
        border-radius: 3px;
      }

      pre code {
        background: none;
        padding: 0;
      }
    </style>
  </head>
  <body>
    <header class="page-header">
      <h1>Watson Works</h1>
    </header>
    <main class="content">
      <slot />
    </main>
    <style>
      .page-header {
        padding: 3rem 2rem;
        text-align: center;
        border-bottom: 1px solid #c9b99a;
        margin-bottom: 3rem;
      }

      .page-header h1 {
        font-family: "Playfair Display", serif;
        font-size: 1.8rem;
        font-weight: 400;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      .content {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 2rem 6rem;
      }
    </style>
  </body>
</html>
