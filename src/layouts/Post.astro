---
interface Props {
  title: string;
  date: string;
  description: string;
}

const { title, date, description } = Astro.props;

const formatted = new Date(date + 'T12:00:00').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<style>
  .post-header {
    margin-bottom: 3rem;
  }

  .post-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 0.5rem;
  }

  .post-title {
    font-size: 1.75rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .post-body :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-body :global(h2) {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.01em;
  }

  .post-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 500;
    margin: 2rem 0 0.75rem;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.35rem;
  }

  .post-body :global(blockquote) {
    border-left: 2px solid #333;
    padding-left: 1rem;
    color: #aaa;
    margin: 1.5rem 0;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid #222;
    margin: 2.5rem 0;
  }

  .back-link {
    display: inline-block;
    margin-top: 4rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    color: #666;
    text-decoration: none;
  }

  .back-link:hover {
    color: #e8e4d9;
  }
</style>

<div class="post-header">
  <div class="post-date">{formatted}</div>
  <h1 class="post-title">{title}</h1>
</div>
<div class="post-body">
  <slot />
</div>
<a href="/" class="back-link">&larr; back</a>
